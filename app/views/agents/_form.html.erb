<%= form_with model: @agent, html: { multipart: true }, class: "space-y-6 bg-green-200" do |form| %>

  <!-- Name -->
  <div>
    <%= form.label :fullname, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :fullname,
          class: "w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 bg-white" %>
  </div>

  <!-- Phone -->
  <div>
    <%= form.label :phone, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :phone,
          class: "w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 bg-white" %>
  </div>

  <!-- Bio -->
  <div>
    <%= form.label :bio, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :bio,
          rows: 5,
          class: "w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 bg-white" %>
  </div>

  <!-- Photo -->
  <div>
    <%= form.label :photos, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.file_field :photos,
          multiple: true,
          class: "w-full border-gray-300 rounded-lg shadow-sm bg-white p-2 cursor-pointer" %>
  </div>

  <!-- Error Messages -->
  <% if agent.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg">
      <h2 class="font-semibold mb-2">
        <%= pluralize(agent.errors.count, "error") %> prohibited this agent profile from being saved:
      </h2>
      <ul class="list-disc pl-5 space-y-1">
        <% agent.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Submit Button -->
  <div>
    <%= form.submit "Save",
          class: "bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition font-medium cursor-pointer" %>
  </div>

<% end %>