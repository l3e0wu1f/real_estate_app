<% content_for :fullname, @agent.fullname %>

<div class="max-w-5xl mx-auto py-8 space-y-8">

  <!-- Notice -->
  <% if notice.present? %>
    <p class="text-green-600 bg-green-50 border border-green-200 px-4 py-2 rounded">
      <%= notice %>
    </p>
  <% end %>

  <!-- Name -->
  <h1 class="text-4xl font-bold text-gray-900">
    <%= @agent.fullname %>
  </h1>

  <!-- Thumbnail -->
  <% if @agent.photos.attached? %>
    <%= image_tag @agent.photos.first.variant(resize_to_fill: [1200, 600]),
          class: "w-1/3 h-36 object-contain rounded-lg shadow" %>
  <% else %>
    <div class="w-1/3 h-36 bg-gray-200 flex items-center justify-center text-gray-500 rounded-lg">
      No Photo Available
    </div>
  <% end %>

  <!-- Agent Details -->
  <div class="bg-white shadow rounded-lg p-6 space-y-4">
    <p class="text-2xl font-semibold text-blue-600">
      <span class="text-black">Contact:</span> <%= @agent.phone %>
    </p>

    <div class="pt-4 border-t border-gray-200">
      <p class="text-gray-800 leading-relaxed whitespace-pre-line">
        <%= @agent.bio %>
      </p>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-between pt-4">
    <div class="space-x-4">
      <%= link_to "Edit this agent profile",
            edit_agent_path(@agent),
            class: "text-blue-600 hover:underline font-medium" %>

      <%= link_to "Back to agents",
            agents_path,
            class: "text-gray-600 hover:text-gray-800" %>
    </div>

    <%= button_to "Delete",
          @agent,
          method: :delete,
          data: { confirm: "Are you sure?" },
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 transition" %>
  </div>

</div>