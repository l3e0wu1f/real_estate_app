<p style="color: green"><%= notice %></p>

<% content_for :title, "Properties" %>

<h1 class="text-3xl font-bold mb-6">Available Listings</h1>

<div id="properties">
  <div class="bg-white shadow p-4 pb-6 rounded mb-6">
    <%= form_with url: properties_path, method: :get, local: true do |f| %>
      <div class="p-4 pb-0">
        <%= f.text_field :q, placeholder: "Search keywords…", class: "border p-2 rounded w-full" %>
      </div>
      <div class="grid grid-cols-2 gap-4 p-4">
        <%= f.number_field :min_price, placeholder: "Min price", class: "border p-2 rounded" %>
        <%= f.number_field :max_price, placeholder: "Max price", class: "border p-2 rounded" %>
        <%= f.number_field :bedrooms, placeholder: "Bedrooms", class: "border p-2 rounded" %>
        <%= f.number_field :bathrooms, placeholder: "Bathrooms", class: "border p-2 rounded" %>
      </div>

      <%= f.submit "Search", class: "ml-4 mt-4 bg-blue-600 text-white px-4 py-2 rounded" %>
      <div class="ml-4 inline">
        <%= link_to "Reset filters", properties_path %>
      </div>
    <% end %>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 p-4">
    <% @properties.each do |property| %>
      <%= render partial: "property", locals: { property: property } %>
    <% end %>
  </div>

  <%= link_to "Create new property listing", new_property_path %>
</div>