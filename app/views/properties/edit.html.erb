<% content_for :title, "Editing Property" %>

<div class="max-w-3xl mx-auto">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Edit Property</h1>
    <p class="text-gray-600">Update the details of this listing below.</p>
  </div>

  <!-- Form Card -->
  <div class="bg-green-200 shadow rounded-lg p-6">
    <%= render "form", property: @property %>
  </div>

  <!-- Footer Actions -->
  <div class="mt-6 flex items-center justify-between">
    <%= link_to "View listing",
          @property,
          class: "text-blue-600 hover:underline font-medium" %>

    <%= link_to "Back to properties",
          properties_path,
          class: "text-gray-600 hover:text-gray-800" %>
  </div>
</div>