<% content_for :title, @property.title %>

<div class="max-w-5xl mx-auto py-8 space-y-8">

  <!-- Notice -->
  <% if notice.present? %>
    <p class="text-green-600 bg-green-50 border border-green-200 px-4 py-2 rounded">
      <%= notice %>
    </p>
  <% end %>

  <!-- Title -->
  <h1 class="text-4xl font-bold text-gray-900">
    <%= @property.title %>
  </h1>

  <!-- Thumbnail -->
  <% if @property.photos.attached? %>
    <%= image_tag @property.photos.first.variant(:hero), class: "w-full h-80 object-cover rounded-lg shadow" %>
  <% else %>
    <div class="w-full h-80 bg-gray-200 flex items-center justify-center text-gray-500 rounded-lg">
      No Photo Available
    </div>
  <% end %>

  <!-- Property Details -->
  <div class="flex">
    <div class="bg-white shadow rounded-lg p-6 space-y-4 w-1/2">
      <p class="text-2xl font-semibold text-blue-600">
        $<%= number_with_delimiter(@property.price) %>
      </p>

      <div class="grid text-gray-700">
        <p><span class="font-medium">Bedrooms:</span> <%= @property.bedrooms %>
          <span class="ml-4 font-medium">Bathrooms:</span> <%= @property.bathrooms %>
        </p>
        <p class="mt-2"><span class="font-medium">Address:</span> <%= @property.address %></p>
      </div>

      <div class="pt-2 border-t border-gray-200">
        <p class="text-gray-800 leading-relaxed whitespace-pre-line">
          <%= @property.description %>
        </p>
      </div>
    </div>

    <div id="property-map" class="w-1/2 h-80 rounded-lg shadow"
      data-controller="map"
      data-lat="<%= @property.latitude %>"
      data-lng="<%= @property.longitude %>">
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-between pt-4">
    <div class="space-x-4">
      <%= link_to "Edit this property",
            edit_property_path(@property),
            class: "text-blue-600 hover:underline font-medium" %>

      <%= link_to "Back to properties",
            properties_path,
            class: "text-gray-600 hover:text-gray-800" %>
    </div>

    <%= button_to "Delete",
          @property,
          method: :delete,
          data: { confirm: "Are you sure?" },
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 transition" %>
  </div>

</div>